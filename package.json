{
  "name": "node-template",
  "version": "0.1.0",
  "description": "A single-package Node/TypeScript library template.",
  "type": "module",
  "license": "MIT",
  "author": "sksizer",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:ci": "biome ci .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=high",
    "lint:deps": "knip",
    "metrics": "scc src",
    "lint:package": "publint",
    "check:types": "attw --pack . --profile esm-only",
    "package-check": "npm run build && npm run lint:package && npm run check:types",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@biomejs/biome": "2.5.2",
    "@types/node": "22.20.0",
    "@vitest/coverage-v8": "4.1.9",
    "knip": "5.88.1",
    "publint": "0.3.21",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
